{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "command": "bash",
      "label": "Install dependencies",
      "args": ["scripts/install_dependencies.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Start client",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^X \\[(ERROR)\\] ((TS|NG)\\d+): (.*)$",
            "severity": 1,
            "code": 2,
            "message": 4
          },
          {
            "regexp": ""
          },
          {
            "regexp": "^\\s*(.*):(\\d+):(\\d+):$",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected\\. Rebuilding\\.\\.\\."
          },
          "endsPattern": {
            "regexp": "Application bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "type": "shell",
      "label": "Pod up",
      "command": "scripts/pod_up.sh",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "Pod down",
      "command": "scripts/pod_down.sh",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "Dev up",
      "command": "scripts/dev_up.sh",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "Dev down",
      "command": "scripts/dev_down.sh",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "command": "scripts/deploy.sh",
      "label": "Deploy",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "Run Playwright Tests",
      "command": "npm test",
      "options": {
        "cwd": "${workspaceFolder}/test"
      },
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
